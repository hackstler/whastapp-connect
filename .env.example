# ── Backbone Connection ────────────────────────────────────────────────────────

# URL base del backbone API, sin path ni slash final (REQUERIDO)
BACKBONE_URL=http://localhost:3000

# Secret compartido con el backbone para firmar JWT de servicio (REQUERIDO)
# Debe ser exactamente el mismo valor que JWT_SECRET en el rag-agent-backbone.
# Genera uno con: openssl rand -hex 32
JWT_SECRET=

# ── WhatsApp ──────────────────────────────────────────────────────────────────

# Ruta base para las sesiones de WhatsApp por usuario (usar volumen persistente en producción)
SESSION_BASE_PATH=.wwebjs_auth

# Intervalo de polling al backbone para descubrir sesiones nuevas (ms)
SESSION_POLL_INTERVAL_MS=60000

# TTL del cache LRU de deduplicación en milisegundos (default: 5 minutos)
DEDUP_TTL_MS=300000

# Número máximo de entradas en el cache LRU
DEDUP_MAX_SIZE=1000

# ── Session Limits ─────────────────────────────────────────────────────────────

# Máximo de sesiones WhatsApp simultáneas (cada una lanza un Chromium ~500-700MB)
MAX_SESSIONS=3

# Polls consecutivos en los que un usuario debe faltar del backbone antes de tear down
BACKBONE_MISS_THRESHOLD=3

# Tiempo máximo (ms) que una sesión puede estar sin QR ni ready antes de considerarla zombie
ZOMBIE_TIMEOUT_MS=300000
